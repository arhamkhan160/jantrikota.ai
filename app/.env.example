# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored — never commit real keys.

APP_ENV=development
LOG_LEVEL=info
MODEL_DIR=./models
DATASET_DIR=./datasets

# ── LLM ────────────────────────────────────────────────────────────────────
# Multiple keys, comma-separated → round-robined per call (spreads rate limits).
# All keys must be the SAME provider (they share LLM_MODEL + LLM_BASE_URL).
LLM_API_KEYS=key_one,key_two,key_three
# Single key alternative (used only if LLM_API_KEYS is blank):
# LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Blank = OpenAI. Groq: https://api.groq.com/openai/v1  OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=

# ── Embeddings (dataset-search ranking; optional) ──────────────────────────
EMBED_MODEL=text-embedding-3-small
# Blank EMBED_API_KEY reuses the first LLM key. Note: Groq has no embeddings —
# set EMBED_BASE_URL/EMBED_API_KEY to an embeddings-capable provider if needed.
EMBED_API_KEY=
EMBED_BASE_URL=

# ── Kaggle source (only if you use kaggle:*) ───────────────────────────────
# KAGGLE_USERNAME=
# KAGGLE_KEY=
